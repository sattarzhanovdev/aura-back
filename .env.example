# For testing on a physical device via Expo Go, add your machine's LAN IP
# here too (e.g. 192.168.1.20) -- "localhost" only resolves from the same
# machine, not from a phone on the same network.
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=

OPENWEATHER_API_KEY=
KIE_API_KEY=
KIE_API_BASE=https://api.kie.ai/api/v1
PUBLIC_BASE_URL=http://localhost:8000
